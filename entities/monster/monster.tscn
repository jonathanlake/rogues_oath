; Windup white-flash material (v0.6.1). resource_local_to_scene = true so EACH monster instance
; gets its OWN ShaderMaterial copy — a scene-assigned material is shared by default, which with
; one goblin is moot but would cross-bleed the flash across every monster once multiple spawn.
[sub_resource type="ShaderMaterial" id="ShaderMaterial_flash"]
resource_local_to_scene = true
shader = ExtResource("6_flash")
shader_parameter/flash_amount = 0.0

