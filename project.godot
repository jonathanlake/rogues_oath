; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Rogue's Oath"
config/version="0.5.2"
config/tags=PackedStringArray("2d", "multiplayer")
run/main_scene="res://ui/main_menu/main_menu.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://autoloads/game_manager.gd"
NetworkManager="*res://autoloads/network_manager.gd"
NetEvents="*res://autoloads/net_events.gd"
GameEvents="*res://autoloads/game_events.gd"
Debug="*res://debug/debug.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/mode=2
window/size/resizable=false
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

